### --- PYTHON --- ###
# Byte-compiled / optimized / DLL files
__pycache__/
*.pyc
*.pyo
*.pyd

# Entornos virtuales
venv/
.venv/
env/
ENV/
bin/
lib64/

### --- WEB FRAMEWORKS (Flask/Django) --- ###
# Archivos de variables de entorno (¡CRÍTICO: No subir secretos!)
.env
.env.local
.env.*.local
instance/
.webassets-cache

### --- BASES DE DATOS --- ###
# Archivos de SQLite y archivos temporales de escritura
*.db
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

### --- DISTRIBUCIÓN Y COMPILACIÓN --- ###
# Archivos generados al empaquetar la app
dist/
*.egg-info/
*.deb
build_deb/
build/work/
build/license_runtime_config.json

### --- ESPECÍFICOS DEL PROYECTO --- ###
# Directorios de código fuente externo o compilados locales
nexar_tienda/
nexar_tienda_linux/
nexar_tienda_windows/

### --- IDE / EDITORES --- ###
# Configuración de VS Code
.vscode/
# Si usas PyCharm
.idea/

### --- SISTEMA OPERATIVO / LOGS --- ###
# Logs del sistema y de la aplicación
*.log
npm-debug.log*

# Archivos basura de macOS y Windows
.DS_Store
Thumbs.db

### --- RESPALDOS Y ARCHIVOS GRANDES --- ###
# Copias de seguridad y archivos comprimidos
*.zip
*.tar.gz
*.rar
respaldo/

### --- llaves SSH y archivos sensibles --- ###
*.pem
*.key
*.crt
*.cache.json
*_cache.json
license_cache.json
license.json
config/license.json
secret.key
.port
.codex

### --- Scripts de despliegue y archivos de configuración local --- ###
scripts/*